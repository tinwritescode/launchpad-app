// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "cockroachdb"
    url      = env("DATABASE_URL")
}

enum AccessType {
    PUBLIC
    PRIVATE
    COMMUNITY
}

enum Status {
    DRAFT
    SUBMITTED
    PENDING_APPROVAL
    APPROVED
    REJECTED
    ONGOING
    COMPLETED
}

model User {
    id            String   @id @default(uuid())
    createdAt     DateTime @default(now())
    updatedAt     DateTime @updatedAt
    walletAddress String   @unique
}

model Chain {
    id      String    @id @default(uuid())
    name    String
    image   String
    Project Project[]
}

model TokenomicsItem {
    id        String  @id @default(uuid())
    name      String
    value     Int
    Project   Project @relation(fields: [projectId], references: [id])
    projectId String
}

model Project {
    id        String   @id @default(uuid())
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    pricePerToken      Float
    paymentTokenSymbol String
    tokenSymbol        String
    name               String
    tokenTicker        String? @default("https://upload.wikimedia.org/wikipedia/commons/1/14/No_Image_Available.jpg?20200913095930")

    status         Status   @default(DRAFT)
    startTime      DateTime
    duration       Int
    targettedRaise Int

    allocation         String?
    participants       Int?
    Token              Token[]
    summaryContent     String?
    videoURL           String?
    ScheduleRound      ScheduleRound[]
    scheduleOpenDate   DateTime?
    scheduleCloseDate  DateTime?
    comparisionContent String?
    TokenomicsItem     TokenomicsItem[]
    roadmapContent     String?
    Chain              Chain?           @relation(fields: [chainId], references: [id])
    chainId            String?
}

model Token {
    id          String   @id @default(uuid())
    Project     Project  @relation(fields: [projectId], references: [id])
    projectId   String
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
    name        String
    symbol      String
    decimals    Int
    totalSupply Int
    address     String
}

model ScheduleRound {
    id        String   @id @default(uuid())
    Project   Project  @relation(fields: [projectId], references: [id])
    projectId String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    name      String
    startTime DateTime
    endTime   DateTime
}
